{
  "info": {
    "name": "Warehouse Space Optimization API",
    "description": "Complete API test collection for Warehouse Space Optimization System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000" },
    { "key": "access_token", "value": "" },
    { "key": "refresh_token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/register/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"email\": \"test@example.com\",\n  \"password\": \"TestPass123!\",\n  \"role\": \"staff\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('access_token', json.access);",
                  "pm.collectionVariables.set('refresh_token', json.refresh);",
                  "pm.test('Login returns 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has access token', () => pm.expect(json.access).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/login/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"Admin123!\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/token/refresh/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
            }
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/auth/profile/",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "Login Wrong Password (401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Wrong password returns 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/login/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"wrongpassword\"\n}"
            }
          }
        },
        {
          "name": "Protected Without Token (401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('No token returns 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/warehouses/warehouses/"
          }
        }
      ]
    },
    {
      "name": "Warehouses",
      "item": [
        {
          "name": "List Warehouses",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has results', () => pm.expect(pm.response.json()).to.have.property('results'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/warehouses/warehouses/",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "Create Warehouse",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Created 201', () => pm.response.to.have.status(201));",
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('warehouse_id', json.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/warehouses/warehouses/",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Warehouse\",\n  \"location\": \"Chennai\",\n  \"code\": \"TW001\"\n}"
            }
          }
        },
        {
          "name": "Get Warehouse by ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/warehouses/warehouses/1/",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "Update Warehouse",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/warehouses/warehouses/1/",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Warehouse\",\n  \"location\": \"Mumbai\",\n  \"code\": \"TW001\"\n}"
            }
          }
        },
        {
          "name": "Search Warehouses",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/warehouses/warehouses/?search=main",
              "query": [{ "key": "search", "value": "main" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "List Zones",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/warehouses/zones/",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "List Racks",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/warehouses/racks/",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "List Bins",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/warehouses/bins/",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        }
      ]
    },
    {
      "name": "Inventory",
      "item": [
        {
          "name": "List Products",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/inventory/products/",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/inventory/products/",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Product\",\n  \"sku\": \"TEST-001\",\n  \"category\": 1,\n  \"unit_price\": 99.99,\n  \"reorder_level\": 10\n}"
            }
          }
        },
        {
          "name": "Search Products by SKU",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/inventory/products/?search=TEST",
              "query": [{ "key": "search", "value": "TEST" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "List Categories",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/inventory/categories/",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "List Inventory Items",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/inventory/items/",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "Stock Movement — Stock In",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Movement created 201', () => pm.response.to.have.status(201));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/inventory/movements/",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product\": 1,\n  \"bin\": 1,\n  \"movement_type\": \"in\",\n  \"quantity\": 50,\n  \"note\": \"Initial stock\"\n}"
            }
          }
        },
        {
          "name": "Stock Movement — Stock Out",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/inventory/movements/",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product\": 1,\n  \"bin\": 1,\n  \"movement_type\": \"out\",\n  \"quantity\": 10,\n  \"note\": \"Customer order\"\n}"
            }
          }
        },
        {
          "name": "List Stock Movements",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/inventory/movements/",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        }
      ]
    },
    {
      "name": "Space Optimization & AI",
      "item": [
        {
          "name": "Recommend Bin (Basic)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has recommended', () => pm.expect(pm.response.json()).to.have.property('recommended'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/warehouses/recommend-bin/?quantity=10&warehouse_id=1",
              "query": [
                { "key": "quantity", "value": "10" },
                { "key": "warehouse_id", "value": "1" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "AI Bin Recommendation",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 200', () => pm.response.to.have.status(200));",
                  "pm.test('AI powered flag', () => pm.expect(pm.response.json().ai_powered).to.be.true);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/warehouses/ai-recommend/?product_id=1&quantity=10",
              "query": [
                { "key": "product_id", "value": "1" },
                { "key": "quantity", "value": "10" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "Utilization Report",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has report array', () => pm.expect(pm.response.json().report).to.be.an('array'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/warehouses/utilization-report/",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "Reorder Predictions",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has predictions', () => pm.expect(pm.response.json()).to.have.property('predictions'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/warehouses/reorder-predictions/",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "Demand Forecast",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/warehouses/demand-forecast/?product_id=1",
              "query": [{ "key": "product_id", "value": "1" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "Dashboard Summary",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has total_warehouses', () => pm.expect(pm.response.json()).to.have.property('total_warehouses'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/warehouses/dashboard/summary/",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        }
      ]
    },
    {
      "name": "Approvals",
      "item": [
        {
          "name": "List Approvals",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/approvals/",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "Create Approval Request",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Created 201', () => pm.response.to.have.status(201));",
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('approval_id', json.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/approvals/",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"request_type\": \"stock_request\",\n  \"notes\": \"Need 100 units of Product A\"\n}"
            }
          }
        },
        {
          "name": "Approve Request",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/approvals/1/approve/",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "Reject Request",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/approvals/1/reject/",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "List Notifications",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/notifications/",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "Mark Notification Read",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/api/notifications/1/",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"is_read\": true\n}"
            }
          }
        }
      ]
    }
  ]
}